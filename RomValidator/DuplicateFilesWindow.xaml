<Window x:Class="RomValidator.DuplicateFilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RomValidator"
        mc:Ignorable="d"
        Title="Duplicate Files Detected"
        Height="600"
        Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="SingleBorderWindow">
    
    <Window.Resources>
        <Style x:Key="HeaderTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        
        <Style x:Key="LabelTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="15,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#FF2196F3" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="AlternatingListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                <Setter Property="Background" Value="Transparent" />
                            </Trigger>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#F0F0F0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E3F2FD" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#BBDEFB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Duplicate Files Detected" Style="{StaticResource HeaderTextBlockStyle}" />
        
        <Border Grid.Row="1" Background="#FFF3E0" BorderBrush="#FFCC80" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Warning: Duplicate ROMs detected in the input folder!" FontWeight="Bold" Foreground="#E65100" />
                <TextBlock Text="These are the same ROM data stored under different filenames." Margin="0,5,0,0" />
                <TextBlock Text="Consider removing duplicates before exporting the DAT file." Margin="0,2,0,0" />
            </StackPanel>
        </Border>
        
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="3" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Duplicate Groups:" Style="{StaticResource LabelTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Text=" (same SHA256 hash, different filenames)" Margin="5,0,0,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Name="DuplicateCountText" FontWeight="Bold" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                
                <ListView Grid.Row="1" Name="DuplicateListView" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" 
                          AlternationCount="2" ItemContainerStyle="{StaticResource AlternatingListViewItemStyle}">
                    <ListView.View>
                        <GridView>
                                <GridViewColumn Header="SHA256 Hash" Width="300">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="local:DuplicateGroup">
                                        <TextBlock Text="{Binding Hash}" FontFamily="Consolas" TextTrimming="CharacterEllipsis" 
                                                   ToolTip="{Binding Hash}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Filenames" Width="450">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="local:DuplicateGroup">
                                        <TextBlock Text="{Binding Filenames}" TextTrimming="CharacterEllipsis" 
                                                   ToolTip="{Binding Filenames}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>
        
        <Button Grid.Row="3" Name="CloseButton" Content="Close" Style="{StaticResource CloseButtonStyle}" 
                HorizontalAlignment="Right" Width="100" Click="CloseButton_Click" />
    </Grid>
</Window>