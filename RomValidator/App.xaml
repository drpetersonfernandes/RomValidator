<Application x:Class="RomValidator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WPF-UI Fluent Design System - Dark Theme -->
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- ============================================ -->
            <!-- COLORS - Professional Fluent Dark Palette    -->
            <!-- A small, cohesive palette. One blue accent,   -->
            <!-- semantic green/red, and neutral grays only.   -->
            <!-- ============================================ -->

            <!-- Surfaces / Backgrounds -->
            <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1B1B1B" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="#272727" />
            <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#2F2F2F" />
            <SolidColorBrush x:Key="SurfaceLightBrush" Color="#232323" />
            <SolidColorBrush x:Key="LightBackgroundBrush" Color="#232323" />
            <SolidColorBrush x:Key="StatusBarGrayBrush" Color="#202020" />
            <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#333333" />
            <SolidColorBrush x:Key="BorderGrayBrush" Color="#383838" />

            <!-- Primary Accent (single blue) -->
            <SolidColorBrush x:Key="PrimaryBlueBrush" Color="#0078D4" />
            <SolidColorBrush x:Key="AccentBlueBrush" Color="#0078D4" />
            <SolidColorBrush x:Key="HoverBlueBrush" Color="#1A88E0" />
            <SolidColorBrush x:Key="PressedBlueBrush" Color="#006CBE" />

            <!-- Semantic: Success (green) -->
            <SolidColorBrush x:Key="SuccessGreenBrush" Color="#107C10" />
            <SolidColorBrush x:Key="SuccessGreenHoverBrush" Color="#0E6B0E" />
            <SolidColorBrush x:Key="SuccessGreenPressedBrush" Color="#0C5D0C" />

            <!-- Semantic: Error (red) -->
            <SolidColorBrush x:Key="ErrorRedBrush" Color="#C42B1C" />
            <SolidColorBrush x:Key="ErrorRedHoverBrush" Color="#B02318" />
            <SolidColorBrush x:Key="ErrorRedPressedBrush" Color="#9A1E14" />
            <SolidColorBrush x:Key="DarkRedBrush" Color="#F1707B" />

            <!-- Neutral (secondary) buttons - replaces the old orange/gray/purple noise -->
            <SolidColorBrush x:Key="NeutralGrayBrush" Color="#3A3A3A" />
            <SolidColorBrush x:Key="NeutralGrayHoverBrush" Color="#464646" />
            <SolidColorBrush x:Key="NeutralGrayPressedBrush" Color="#2F2F2F" />

            <!-- Legacy "warning orange" keys remapped to neutral secondary (Download/Reset) -->
            <SolidColorBrush x:Key="WarningOrangeBrush" Color="#3A3A3A" />
            <SolidColorBrush x:Key="WarningOrangeHoverBrush" Color="#464646" />
            <SolidColorBrush x:Key="WarningOrangePressedBrush" Color="#2F2F2F" />

            <!-- Legacy "purple" key remapped to accent (Export DAT) -->
            <SolidColorBrush x:Key="InfoPurpleBrush" Color="#0078D4" />

            <!-- Base -->
            <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="BlackBrush" Color="#000000" />

            <!-- Text -->
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F3F3F3" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#C5C5C5" />
            <SolidColorBrush x:Key="GrayTextBrush" Color="#9A9A9A" />
            <SolidColorBrush x:Key="DarkGrayTextBrush" Color="#B8B8B8" />

            <!-- Stats accent text (muted, readable on dark) -->
            <SolidColorBrush x:Key="SuccessGreenTextBrush" Color="#6CCB5F" />
            <SolidColorBrush x:Key="ErrorRedTextBrush" Color="#F1707B" />
            <SolidColorBrush x:Key="WarningGoldenrodTextBrush" Color="#FFC83D" />
            <SolidColorBrush x:Key="InfoBlueTextBrush" Color="#60CDFF" />

            <!-- Duplicate Window -->
            <SolidColorBrush x:Key="DuplicateWarningBackgroundBrush" Color="#2A2410" />
            <SolidColorBrush x:Key="DuplicateWarningBorderBrush" Color="#4A3F1A" />
            <SolidColorBrush x:Key="DuplicateWarningTextBrush" Color="#FFC83D" />
            <SolidColorBrush x:Key="DuplicateWindowCloseButtonBackgroundBrush" Color="#0078D4" />

            <!-- ============================================ -->
            <!-- GLOBAL IMPLICIT STYLES                       -->
            <!-- Only for controls WPF-UI doesn't theme       -->
            <!-- (TextBlock/Label are not Controls).          -->
            <!-- ============================================ -->

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style TargetType="StatusBar">
                <Setter Property="Background" Value="{StaticResource StatusBarGrayBrush}" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="Padding" Value="5" />
            </Style>

            <Style TargetType="StatusBarItem">
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <Style TargetType="Frame">
                <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}" />
            </Style>

            <!-- WPF-UI does not theme ListView; give it a dark surface -->
            <Style TargetType="ListView">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <!-- WPF-UI does not theme ListViewItem; keep text light on dark -->
            <Style TargetType="ListViewItem">
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="8,4" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource HoverBackgroundBrush}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource AccentBlueBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- WPF-UI does not theme GridView column headers; make them dark-aware -->
            <Style TargetType="GridViewColumnHeader">
                <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}" />
                <Setter Property="BorderThickness" Value="0,0,1,1" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GridViewColumnHeader">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      RecognizesAccessKey="True" />
                                    <Thumb x:Name="PART_HeaderGripper"
                                           HorizontalAlignment="Right"
                                           Width="4"
                                           Margin="0,0,-2,0"
                                           Cursor="SizeWE"
                                           Background="Transparent" />
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource HoverBackgroundBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BorderGrayBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================ -->
            <!-- BUTTON STYLES                                -->
            <!-- ============================================ -->

            <!-- Menu Button Style (MainWindow header nav) - flat, subtle -->
            <Style x:Key="MenuButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="Margin" Value="3,0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource HoverBackgroundBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BorderGrayBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Action Button Style (Shared, accent) -->
            <Style x:Key="ActionButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="15,8" />
                <Setter Property="Margin" Value="5" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
                <Setter Property="Background" Value="{StaticResource AccentBlueBrush}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="{StaticResource BorderGrayBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource GrayTextBrush}" />
                                    <Setter Property="Opacity" Value="0.7" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource HoverBlueBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PressedBlueBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Start Button Style (Green) -->
            <Style x:Key="StartButtonStyle" BasedOn="{StaticResource ActionButtonStyle}" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SuccessGreenBrush}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource SuccessGreenHoverBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource SuccessGreenPressedBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Cancel Button Style (Red) -->
            <Style x:Key="CancelButtonStyle" BasedOn="{StaticResource ActionButtonStyle}" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource ErrorRedBrush}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource ErrorRedHoverBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource ErrorRedPressedBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Secondary/Neutral Button Style (Download, Reset) -->
            <Style x:Key="DownloadButtonStyle" BasedOn="{StaticResource ActionButtonStyle}" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource NeutralGrayBrush}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource NeutralGrayHoverBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource NeutralGrayPressedBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Close Button Style -->
            <Style x:Key="CloseButtonStyle" BasedOn="{StaticResource ActionButtonStyle}" TargetType="Button">
                <Setter Property="Width" Value="100" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>

            <!-- Menu Button Variants (kept for compatibility, unified flat look) -->
            <Style x:Key="MenuButtonPurpleStyle" BasedOn="{StaticResource MenuButtonStyle}" TargetType="Button" />
            <Style x:Key="MenuButtonGrayStyle" BasedOn="{StaticResource MenuButtonStyle}" TargetType="Button" />

            <!-- Accent Action Button (Export DAT) -->
            <Style x:Key="PurpleActionButtonStyle" BasedOn="{StaticResource ActionButtonStyle}" TargetType="Button" />

            <!-- ============================================ -->
            <!-- TEXTBOX STYLES (inherit WPF-UI Fluent look)  -->
            <!-- ============================================ -->

            <Style x:Key="CustomTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="IsReadOnlyCaretVisible" Value="True" />
            </Style>

            <!-- Log Viewer TextBox (monospace) -->
            <Style x:Key="LogViewerTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="FontFamily" Value="Consolas, Courier New, Lucida Console" />
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="AcceptsReturn" Value="True" />
                <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
                <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
                <Setter Property="IsReadOnly" Value="True" />
            </Style>

            <!-- ============================================ -->
            <!-- CHECKBOX STYLES (inherit WPF-UI Fluent look)  -->
            <!-- ============================================ -->

            <!-- Dangerous CheckBox (delete option) -->
            <Style x:Key="DangerousCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                <Setter Property="Foreground" Value="{StaticResource DarkRedBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <!-- ============================================ -->
            <!-- LISTVIEW STYLES                              -->
            <!-- ============================================ -->

            <!-- Alternating ListViewItem Style -->
            <Style x:Key="AlternatingListViewItemStyle" TargetType="ListViewItem">
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}" />
                <Style.Triggers>
                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                        <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}" />
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource HoverBackgroundBrush}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource AccentBlueBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ============================================ -->
            <!-- BORDER STYLES                                -->
            <!-- ============================================ -->

            <!-- Standard Card Border Style -->
            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            </Style>

            <!-- MainWindow Header Bar Border Style -->
            <Style x:Key="MainHeaderBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="Padding" Value="15" />
            </Style>

            <!-- Duplicate Window: Warning Banner Border -->
            <Style x:Key="DuplicateWarningBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource DuplicateWarningBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource DuplicateWarningBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="10" />
            </Style>

            <!-- Duplicate Window: List Container Border -->
            <Style x:Key="DuplicateListContainerBorderStyle" TargetType="Border">
                <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <!-- Duplicate Window: List Header Row Border -->
            <Style x:Key="DuplicateListHeaderBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource LightBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="Padding" Value="10" />
            </Style>

            <!-- Option Card Border Style (for radio button options) -->
            <Style x:Key="OptionCardBorderStyle" TargetType="Border">
                <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="15" />
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>

            <!-- Controls Container Border Style -->
            <Style x:Key="ControlsContainerBorderStyle" TargetType="Border">
                <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="15" />
                <Setter Property="Margin" Value="10" />
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            </Style>

            <!-- Progress Bar Container Border Style -->
            <Style x:Key="ProgressBarContainerStyle" TargetType="Border">
                <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="4" />
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            </Style>

            <!-- Stats Panel Border Style -->
            <Style x:Key="StatsPanelBorderStyle" TargetType="Border">
                <Setter Property="BorderBrush" Value="{StaticResource BorderGrayBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Margin" Value="3" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            </Style>

            <!-- ============================================ -->
            <!-- TEXTBLOCK STYLES                             -->
            <!-- ============================================ -->

            <!-- Header TextBlock Style -->
            <Style x:Key="HeaderTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Margin" Value="0,0,0,15" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <!-- SubHeader TextBlock Style -->
            <Style x:Key="SubHeaderTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Margin" Value="0,0,0,10" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <!-- Label TextBlock Style -->
            <Style x:Key="LabelTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <!-- Option Title TextBlock Style -->
            <Style x:Key="OptionTitleTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <!-- Option Description TextBlock Style -->
            <Style x:Key="OptionDescriptionTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="{StaticResource GrayTextBrush}" />
                <Setter Property="Margin" Value="0,2,0,0" />
            </Style>

            <!-- Gray Description TextBlock Style -->
            <Style x:Key="GrayDescriptionTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{StaticResource GrayTextBrush}" />
                <Setter Property="Margin" Value="0,0,0,15" />
            </Style>

            <!-- ============================================ -->
            <!-- PROGRESSBAR STYLE (inherit WPF-UI Fluent)     -->
            <!-- ============================================ -->

            <Style x:Key="StandardProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                <Setter Property="Height" Value="24" />
            </Style>

            <!-- ============================================ -->
            <!-- GRIDSPLITTER STYLE                           -->
            <!-- ============================================ -->

            <Style x:Key="StandardGridSplitterStyle" TargetType="GridSplitter">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="Background" Value="{StaticResource BorderGrayBrush}" />
                <Setter Property="ShowsPreview" Value="True" />
                <Setter Property="Width" Value="5" />
            </Style>

            <!-- ============================================ -->
            <!-- DUPLICATE WINDOW STYLES                      -->
            <!-- ============================================ -->

            <Style x:Key="DuplicateWindowHeaderTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,10" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <Style x:Key="DuplicateWindowLabelTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <Style x:Key="DuplicateWindowCloseButtonStyle" BasedOn="{StaticResource ActionButtonStyle}" TargetType="Button">
                <Setter Property="Padding" Value="15,6" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <!-- ============================================ -->
            <!-- APPLICATION-SPECIFIC NAMED STYLES            -->
            <!-- ============================================ -->

            <!-- App Title TextBlock (MainWindow header) -->
            <Style x:Key="AppTitleTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0,0,30,0" />
            </Style>

            <!-- Form Hint TextBlock ("Only No-Intro...") -->
            <Style x:Key="FormHintTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontStyle" Value="Italic" />
                <Setter Property="Foreground" Value="{StaticResource GrayTextBrush}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Margin" Value="155,0,0,5" />
            </Style>

            <!-- Section Title ("DAT File Information") -->
            <Style x:Key="SectionTitleTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Margin" Value="0,0,0,10" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <!-- DAT Info Field Label -->
            <Style x:Key="DatFieldLabelTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,5,5" />
                <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            </Style>

            <!-- DAT Info Field Value -->
            <Style x:Key="DatFieldValueTextBlockStyle" TargetType="TextBlock">
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="Margin" Value="0,0,0,5" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <!-- Stats Panel Category Label -->
            <Style x:Key="StatsCategoryTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <!-- Stats Panel Category Label - Semantic color variants -->
            <Style x:Key="StatsCategorySuccessTextBlockStyle" BasedOn="{StaticResource StatsCategoryTextBlockStyle}" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource SuccessGreenTextBrush}" />
            </Style>
            <Style x:Key="StatsCategoryFailedTextBlockStyle" BasedOn="{StaticResource StatsCategoryTextBlockStyle}" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ErrorRedTextBrush}" />
            </Style>
            <Style x:Key="StatsCategoryWarningTextBlockStyle" BasedOn="{StaticResource StatsCategoryTextBlockStyle}" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource WarningGoldenrodTextBrush}" />
            </Style>
            <Style x:Key="StatsCategoryRenamedTextBlockStyle" BasedOn="{StaticResource StatsCategoryTextBlockStyle}" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource InfoBlueTextBrush}" />
            </Style>
            <Style x:Key="StatsCategoryDeletedTextBlockStyle" BasedOn="{StaticResource StatsCategoryTextBlockStyle}" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource DarkRedBrush}" />
            </Style>

            <!-- Stats Panel Value Label -->
            <Style x:Key="StatsValueTextBlockStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,4,0,0" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <!-- Progress Overlay Text -->
            <Style x:Key="ProgressTextBlockStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <!-- Monospace Text (hash values) -->
            <Style x:Key="MonospaceTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Consolas, Courier New, Lucida Console" />
                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Style>

            <!-- Duplicate Warning Title -->
            <Style x:Key="DuplicateWarningTitleTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{StaticResource DuplicateWarningTextBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
