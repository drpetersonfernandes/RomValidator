<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net10.0-windows</TargetFramework>
        <UseWPF>true</UseWPF>
        <LangVersion>14</LangVersion>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <ApplicationIcon>icon\icon.ico</ApplicationIcon>
        <AssemblyVersion>2.5.0</AssemblyVersion>
        <FileVersion>2.5.0</FileVersion>
        <DebugType>embedded</DebugType>
        <DebugSymbols>true</DebugSymbols>
        <IsPackable>false</IsPackable>
        <NeutralLanguage>en</NeutralLanguage>
        <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <DocumentationFile>bin\$(Configuration)\$(TargetFramework)\RomValidator.xml</DocumentationFile>
        <NoWarn>$(NoWarn);1591</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <None Remove="icon.ico" />
        <None Remove="images\about.png" />
        <None Remove="images\exit.png" />
        <None Remove="images\logo.png" />
        <Resource Include="images\logo.png" />

    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="SharpSevenZip" Version="2.0.36" />
    </ItemGroup>

    <!-- Ensure 7z native libraries are copied to output directory with correct naming for each architecture -->
    <ItemGroup>
      <!-- x64 architecture library -->
      <None Include="$(NuGetPackageRoot)\sharpsevenzip\2.0.36\build\x64\7z.dll" Condition="Exists('$(NuGetPackageRoot)\sharpsevenzip\2.0.36\build\x64\7z.dll')">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        <TargetPath>7z_x64.dll</TargetPath>
      </None>
      <!-- ARM64 architecture library -->
      <None Include="$(NuGetPackageRoot)\sharpsevenzip\2.0.36\build\arm64\7z.dll" Condition="Exists('$(NuGetPackageRoot)\sharpsevenzip\2.0.36\build\arm64\7z.dll')">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        <TargetPath>7z_arm64.dll</TargetPath>
      </None>
    </ItemGroup>

    <ItemGroup>
        <None Remove="References\**" />
    </ItemGroup>

    <ItemGroup>
        <Compile Remove="References\**" />
    </ItemGroup>

    <ItemGroup>
        <Page Remove="References\**" />
        <Page Update="Pages\GenerateDatPage.xaml">
          <Generator>MSBuild:Compile</Generator>
          <XamlRuntime>Wpf</XamlRuntime>
          <SubType>Designer</SubType>
        </Page>
        <Page Update="Pages\ValidatePage.xaml">
          <Generator>MSBuild:Compile</Generator>
          <XamlRuntime>Wpf</XamlRuntime>
          <SubType>Designer</SubType>
        </Page>
    </ItemGroup>

    <ItemGroup>
      <Folder Include="Models\NoIntro\" />
    </ItemGroup>

</Project>
