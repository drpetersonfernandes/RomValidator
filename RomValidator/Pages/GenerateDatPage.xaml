<Page x:Class="RomValidator.Pages.GenerateDatPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:models="clr-namespace:RomValidator.Models"
      Title="Generate DAT File"
      d:DesignHeight="768"
      d:DesignWidth="1024"
      mc:Ignorable="d">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Generate DAT File" Style="{StaticResource HeaderTextBlockStyle}" />

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Name="FolderTextBox" Grid.Column="0" Style="{StaticResource CustomTextBoxStyle}" IsReadOnly="True" ToolTip="Selected folder path" />
            <Button Grid.Column="1" Content="Select Folder" Style="{StaticResource ActionButtonStyle}" Margin="10,0,0,0" Click="SelectFolderButton_Click" ToolTip="Choose a folder to hash its files" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Name:" Style="{StaticResource LabelTextBlockStyle}" Margin="0,0,0,5" />
                <TextBox Name="NameTextBox" Style="{StaticResource CustomTextBoxStyle}" ToolTip="DAT file header: Name (e.g., Sega - Mega Drive - Genesis)" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="5,0,5,0">
                <TextBlock Text="Description:" Style="{StaticResource LabelTextBlockStyle}" Margin="0,0,0,5" />
                <TextBox Name="DescriptionTextBox" Style="{StaticResource CustomTextBoxStyle}" ToolTip="DAT file header: Description" />
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                <TextBlock Text="Author:" Style="{StaticResource LabelTextBlockStyle}" Margin="0,0,0,5" />
                <TextBox Name="AuthorTextBox" Style="{StaticResource CustomTextBoxStyle}" ToolTip="DAT file header: Author" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}" Margin="0,10,0,15">
            <ListView Name="HashListView" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" AlternationCount="2" ToolTip="List of files and their calculated hashes" ItemContainerStyle="{StaticResource AlternatingListViewItemStyle}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Filename" Width="250"><GridViewColumn.CellTemplate><DataTemplate DataType="models:GameFile"><TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" ToolTip="{Binding FileName}" /></DataTemplate></GridViewColumn.CellTemplate></GridViewColumn>
                        <GridViewColumn Header="Size" Width="100"><GridViewColumn.CellTemplate><DataTemplate DataType="models:GameFile"><TextBlock Text="{Binding FileSize, StringFormat='{}{0:N0}'}" TextAlignment="Right" /></DataTemplate></GridViewColumn.CellTemplate></GridViewColumn>
                        <GridViewColumn Header="CRC32" Width="80"><GridViewColumn.CellTemplate><DataTemplate DataType="models:GameFile"><TextBlock Text="{Binding Crc32}" FontFamily="Consolas" ToolTip="{Binding ErrorMessage}" /></DataTemplate></GridViewColumn.CellTemplate></GridViewColumn>
                        <GridViewColumn Header="MD5" Width="240"><GridViewColumn.CellTemplate><DataTemplate DataType="models:GameFile"><TextBlock Text="{Binding Md5}" FontFamily="Consolas" ToolTip="{Binding ErrorMessage}" /></DataTemplate></GridViewColumn.CellTemplate></GridViewColumn>
                        <GridViewColumn Header="SHA1" Width="280"><GridViewColumn.CellTemplate><DataTemplate DataType="models:GameFile"><TextBlock Text="{Binding Sha1}" FontFamily="Consolas" ToolTip="{Binding ErrorMessage}" /></DataTemplate></GridViewColumn.CellTemplate></GridViewColumn>
                        <GridViewColumn Header="SHA256" Width="450"><GridViewColumn.CellTemplate><DataTemplate DataType="models:GameFile"><TextBlock Text="{Binding Sha256}" FontFamily="Consolas" ToolTip="{Binding ErrorMessage}" /></DataTemplate></GridViewColumn.CellTemplate></GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <Grid Grid.Row="4" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource ProgressBarContainerStyle}" ToolTip="Overall hashing progress">
                <Grid>
                    <ProgressBar Name="HashProgressBar" Style="{StaticResource StandardProgressBarStyle}" />
                    <TextBlock Name="ProgressText" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                </Grid>
            </Border>
            <TextBlock Grid.Column="1" Name="FileCountText" Text="No files processed" Margin="10,0,0,0" VerticalAlignment="Center" />
        </Grid>

        <UniformGrid Grid.Row="5" Columns="4" HorizontalAlignment="Left">
            <Button Name="StartButton" Content="Start Hashing" Style="{StaticResource StartButtonStyle}" Click="StartButton_Click" IsEnabled="False" ToolTip="Begin hashing files in the selected folder" />
            <Button Name="StopButton" Content="Stop" Style="{StaticResource CancelButtonStyle}" Click="StopButton_Click" IsEnabled="False" ToolTip="Cancel the hashing operation" />
            <Button Content="Reset" Style="{StaticResource DownloadButtonStyle}" Click="ResetButton_Click" ToolTip="Clear all data and start over" />
            <Button Name="ExportDatButton" Content="Export DAT" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource InfoPurpleBrush}" Click="ExportDatButton_Click" IsEnabled="False" ToolTip="Export the results to a DAT file" />
        </UniformGrid>
    </Grid>
</Page>
