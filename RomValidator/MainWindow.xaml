<Window x:Class="RomValidator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ROM Validator" Height="720" Width="1200" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with application title and navigation buttons -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="ROM Validator" FontSize="20" FontWeight="Bold" Foreground="{StaticResource WhiteBrush}" VerticalAlignment="Center" Margin="0,0,30,0" />
                    <Button x:Name="ValidateRomsButton" Content="Validate ROMs" Click="ValidateRoms_Click" Style="{StaticResource MenuButtonStyle}" ToolTip="Validate ROMs against a DAT file" />
                    <Button x:Name="GenerateDatButton" Content="Generate DAT" Click="GenerateDat_Click" Style="{StaticResource MenuButtonStyle}" ToolTip="Generate a DAT file from a folder of ROMs" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="About" Click="About_Click" Style="{StaticResource MenuButtonStyle}" Background="{StaticResource InfoPurpleBrush}" ToolTip="View application information" />
                    <Button Content="Exit" Click="Exit_Click" Style="{StaticResource MenuButtonStyle}" Background="{StaticResource NeutralGrayBrush}" ToolTip="Close the application" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content frame -->
        <Frame Grid.Row="1"
               Name="MainContentFrame"
               NavigationUIVisibility="Hidden"
               Background="{StaticResource LightBackgroundBrush}" />

        <!-- Status bar -->
        <StatusBar Grid.Row="2" Background="{StaticResource StatusBarGrayBrush}" Padding="5">
            <StatusBarItem ToolTip="Current application status">
                <TextBlock x:Name="StatusBarMessageTextBlock" Text="Ready." />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
