<Page x:Class="RomValidator.ValidatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1100"
      Title="Validate ROMs">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Main Controls -->
            <RowDefinition Height="*"/>    <!-- LogViewer & DAT Info Section -->
            <RowDefinition Height="Auto"/> <!-- Stats Panel -->
            <RowDefinition Height="Auto"/> <!-- Progress Bar Area (Combined) -->
        </Grid.RowDefinitions>

        <!-- Main Controls -->
        <Border Grid.Row="0" Style="{StaticResource ControlsContainerBorderStyle}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="ROMs Folder to Scan:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="RomsFolderTextBox" Grid.Column="1" Margin="5,0,5,0" Style="{StaticResource CustomTextBoxStyle}" IsReadOnly="True" ToolTip="Path to the folder containing ROM files"/>
                    <Button x:Name="BrowseRomsFolderButton" Grid.Column="2" Content="Browse..." Click="BrowseRomsFolderButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Select the folder containing your ROM files"/>
                </Grid>

                <Grid Margin="0,10,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="DAT File:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="DatFileTextBox" Grid.Column="1" Margin="5,0,5,0" Style="{StaticResource CustomTextBoxStyle}" IsReadOnly="True" ToolTip="Path to the selected DAT file"/>
                    <Button x:Name="BrowseDatFileButton" Grid.Column="2" Content="Browse..." Click="BrowseDatFileButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Select the DAT file for validation"/>
                </Grid>

                <StackPanel Margin="0,15,0,0" Orientation="Vertical">
                    <CheckBox x:Name="MoveSuccessCheckBox" Content="Move successful items to '_success' folder" IsChecked="True" VerticalAlignment="Center" Margin="5" ToolTip="If checked, valid ROMs will be moved to the '_success' subfolder"/>
                    <CheckBox x:Name="MoveFailedCheckBox" Content="Move failed/unknown items to '_fail' folder" IsChecked="True" Margin="5" VerticalAlignment="Center" ToolTip="If checked, invalid or unknown ROMs will be moved to the '_fail' subfolder"/>
                    <CheckBox x:Name="DeleteFailedCheckBox" Content="Permanently delete failed/unknown files (⚠️ irreversible)" IsChecked="False" Margin="5" VerticalAlignment="Center" Foreground="{StaticResource ErrorRedBrush}" FontWeight="SemiBold" ToolTip="If checked, invalid or unknown ROMs will be permanently deleted from disk. This action cannot be undone!"/>
                    <CheckBox x:Name="RenameMatchedFilesCheckBox" Content="Automatically rename files when hash matches but filename differs" IsChecked="True" Margin="5" VerticalAlignment="Center" ToolTip="If checked, files with matching hashes but different names will be renamed to match the DAT entry"/>
                </StackPanel>

                <StackPanel Margin="0,15,0,0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="StartValidationButton" Content="Start Validation" Click="StartValidationButton_Click" Style="{StaticResource StartButtonStyle}" ToolTip="Begin validating ROMs against the DAT file"/>
                    <Button x:Name="DownloadDatFilesButton" Content="Download Dat Files" Click="DownloadDatFilesButton_Click" Style="{StaticResource DownloadButtonStyle}" ToolTip="Open browser to download DAT files"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- LogViewer & DAT Info Section -->
        <Grid Grid.Row="1" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/> <!-- LogViewer column -->
                <ColumnDefinition Width="5"/> <!-- GridSplitter column -->
                <ColumnDefinition Width="250" MinWidth="200"/> <!-- DAT Info column -->
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" ToolTip="Validation logs and details">
                <TextBox x:Name="LogViewer" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Consolas" Background="{StaticResource WhiteBrush}"/>
            </Border>

            <GridSplitter Grid.Column="1" Style="{StaticResource StandardGridSplitterStyle}" />

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="5,0,0,0" ToolTip="Information about the loaded DAT file">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="DAT File Information" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontWeight="SemiBold" Margin="0,0,5,5"/>
                            <TextBlock x:Name="DatNameTextBlock" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" Text="N/A" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" FontWeight="SemiBold" Margin="0,0,5,5"/>
                            <TextBlock x:Name="DatDescriptionTextBlock" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Text="N/A" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Version:" FontWeight="SemiBold" Margin="0,0,5,5"/>
                            <TextBlock x:Name="DatVersionTextBlock" Grid.Row="2" Grid.Column="1" Text="N/A" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Author:" FontWeight="SemiBold" Margin="0,0,5,5"/>
                            <TextBlock x:Name="DatAuthorTextBlock" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Text="N/A" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Homepage:" FontWeight="SemiBold" Margin="0,0,5,5"/>
                            <TextBlock x:Name="DatHomepageTextBlock" Grid.Row="4" Grid.Column="1" Text="N/A" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="URL:" FontWeight="SemiBold" Margin="0,0,5,5"/>
                            <TextBlock x:Name="DatUrlTextBlock" Grid.Row="5" Grid.Column="1" TextWrapping="Wrap" Text="N/A" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="ROM Entries:" FontWeight="SemiBold" Margin="0,10,5,0"/>
                            <TextBlock x:Name="DatRomCountTextBlock" Grid.Row="6" Grid.Column="1" Text="0" Margin="0,10,0,0"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Stats Panel -->
        <Grid Grid.Row="2" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StatsPanelBorderStyle}" ToolTip="Total number of files to process">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="Total Files:" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TotalFilesValue" Text="0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource StatsPanelBorderStyle}" ToolTip="Number of successfully validated files">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="Success:" FontWeight="SemiBold" Foreground="{StaticResource SuccessGreenTextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="SuccessValue" Text="0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource StatsPanelBorderStyle}" ToolTip="Number of files that failed validation">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="Failed:" FontWeight="SemiBold" Foreground="{StaticResource ErrorRedTextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="FailedValue" Text="0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource StatsPanelBorderStyle}" ToolTip="Number of unknown files (not in DAT)">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="Unknown:" FontWeight="SemiBold" Foreground="{StaticResource WarningGoldenrodTextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="UnknownValue" Text="0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource StatsPanelBorderStyle}" ToolTip="Number of files that were renamed to match the DAT entry">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="Renamed:" FontWeight="SemiBold" Foreground="{StaticResource InfoBlueTextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="RenamedValue" Text="0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="5" Style="{StaticResource StatsPanelBorderStyle}" ToolTip="Number of files that were permanently deleted">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="Deleted:" FontWeight="SemiBold" Foreground="{StaticResource DarkRedBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="DeletedValue" Text="0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="6" Style="{StaticResource StatsPanelBorderStyle}" ToolTip="Time elapsed during validation">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="Processing Time:" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ProcessingTimeValue" Text="00:00:00" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Combined Progress Bar Area -->
        <Grid Grid.Row="3" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource ProgressBarContainerStyle}" ToolTip="Validation progress">
                <Grid>
                    <ProgressBar x:Name="ProgressBar" Style="{StaticResource StandardProgressBarStyle}" />
                    <TextBlock x:Name="ProgressText" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Text="" />
                </Grid>
            </Border>
            <Button x:Name="CancelButton" Grid.Column="1" Content="Cancel" Click="CancelButton_Click" Style="{StaticResource CancelButtonStyle}" Margin="10,0,0,0" Visibility="Collapsed" ToolTip="Cancel the validation process"/>
        </Grid>
    </Grid>
</Page>
